{
  "schemaVersion": 1,
  "policyId": "lan-arcade-qa-readiness-v1",
  "tiers": {
    "T0": {
      "rank": 0,
      "label": "Inventory",
      "meaning": "Identity, catalog, or local-file observation only."
    },
    "T1": {
      "rank": 1,
      "label": "Surface",
      "meaning": "Page, service, canvas, or package surface is reachable."
    },
    "T2": {
      "rank": 2,
      "label": "Launch and input",
      "meaning": "The target launches and accepts relevant player input."
    },
    "T3": {
      "rank": 3,
      "label": "Meaningful single-player action",
      "meaning": "A title-specific action changes meaningful game state."
    },
    "T4": {
      "rank": 4,
      "label": "End-to-end multiplayer or persistence",
      "meaning": "Real clients complete a multiplayer flow, or a save/reload flow restores meaningful state."
    }
  },
  "outcomes": [
    "pass",
    "partial",
    "fail",
    "blocked",
    "unverified"
  ],
  "promotionStates": [
    "ready",
    "limited",
    "quarantined",
    "research"
  ],
  "contentTypes": [
    "single-player",
    "hosted",
    "multiplayer",
    "collection",
    "research"
  ],
  "readyThresholds": {
    "single-player": "T3",
    "hosted": "T4",
    "multiplayer": "T4"
  },
  "requireOfflineForReady": true,
  "requireExplicitExpiry": true,
