{
  "version": 1,
  "policy": {
    "defaultMode": "on-demand",
    "maxHeavyServicesRunning": 1,
    "smokeLock": "/tmp/lan-arcade-native-service-smoke.lock",
    "reportDir": "qa/reports/service-smoke",
    "adminRule": "Only execute commands from this allowlist; never accept arbitrary shell from the browser UI."
  },
  "services": [
    {
      "id": "mindustry-lan",
      "label": "Mindustry LAN Server",
      "tier": "native-docker-service",
      "catalogHub": "/mirrors/mindustry-lan/",
      "composeFile": "deploy/mindustry.compose.yml",
      "ports": [
        "6567/tcp",
        "6567/udp"
      ],
      "dataDir": "/var/lib/lan-arcade/mindustry",
      "recommendedMemory": "512 MiB heap for Pi trial; 256 MiB smoke passed on VM",
      "startEnv": {
        "MINDUSTRY_XMX": "512m"
      },
      "healthCheck": "logs contain 'Opened a server' and TCP 6567 accepts connections",
      "smokeStatus": "passed",
      "lastReport": "qa/reports/service-smoke/mindustry-host-final-20260614T001049Z.txt",
      "adminState": "startable"
    },
    {
      "id": "unciv-lan",
      "label": "Unciv LAN Server",
      "tier": "native-docker-service",
      "catalogHub": "/mirrors/unciv-lan/",
      "composeFile": "deploy/unciv.compose.yml",
      "ports": [
        "8090/tcp"
      ],
      "dataDir": "/var/lib/lan-arcade/unciv",
      "recommendedMemory": "-Xms64m -Xmx256m",
      "startEnv": {
        "UNCIV_JAVA_OPTS": "-Xms64m -Xmx256m"
      },
      "healthCheck": "GET /isalive returns authVersion/chatVersion JSON; auth/file loop passes",
      "smokeStatus": "passed",
      "lastReport": "qa/reports/service-smoke/unciv-file-loop-final-20260614T001555Z.json",
      "adminState": "startable"
    },
    {
      "id": "travianz-lan",
      "label": "TravianZ LAN Service",
      "tier": "native-docker-service-candidate",
      "catalogHub": "/mirrors/travianz-lan/",
      "composeFile": "deploy/travianz.compose.yml",
      "ports": [
        "8092/tcp",
        "8093/tcp admin profile only"
      ],
      "dataDir": "$HOME/.lan-arcade/services/travianz/mysql",
      "cachedArtifacts": [
        "/mirrors/games/downloads/native/travian-like/travianz/travianz-d00826167857.tar.gz"
      ],
      "recommendedMemory": "Docker Compose caps MariaDB and web containers at 768 MiB each; start on demand, not for Pi profile",
      "healthCheck": "TravianZ home/register pages render, player registration succeeds, login reaches village gameplay, and Playwright blocks off-LAN requests",
      "smokeStatus": "install-register-login-gameplay-passed",
      "lastReport": "qa/reports/travianz-smoke-20260620T102346Z/result.json",
      "adminState": "startable-on-demand"
    },
    {
      "id": "freeciv-lan",
      "label": "Freeciv LAN Server",
      "tier": "native-package-client-and-server",
      "catalogHub": "/mirrors/freeciv-lan/",
      "packageNames": [
        "freeciv-server",
        "freeciv-client-gtk3"
      ],
      "ports": [
        "5556/tcp"
      ],
      "dataDir": "/var/lib/lan-arcade/freeciv",
      "recommendedMemory": "server smoke used about 48 MiB RSS; GTK client launch smoke pending real join",
      "healthCheck": "freeciv-server starts on 127.0.0.1:5556, TCP accepts, client launches under Xvfb",
      "smokeStatus": "server-tcp-and-client-launch-passed",
      "lastReport": "qa/reports/service-smoke/freeciv-lan-20260614T053247Z/report.txt; qa/reports/native-client-launch/freeciv-lan-20260614T054915Z/report.txt",
      "adminState": "server-smoked"
    },
    {
      "id": "stendhal-lan",
      "label": "Stendhal LAN Hub",
      "tier": "native-client-and-future-server",
      "catalogHub": "/mirrors/stendhal-lan/",
      "cachedArtifacts": [
        "/mirrors/stendhal/stendhal.zip",
        "/mirrors/stendhal/stendhalgame.org/download/org.stendhalgame.client-1048005-debug.apk"
      ],
      "ports": [],
      "healthCheck": "cached stendhal.zip passes archive integrity; local server launch and two-client smoke still pending",
      "smokeStatus": "artifact-zip-smoke-passed",
      "adminState": "research",
      "lastReport": "qa/reports/service-smoke/stendhal-lan-20260614T053259Z/report.txt"
    },
    {
      "id": "openttd-lan",
