      ],
      "lastReport": "qa/reports/native-client-launch/freecol-lan-20260620T095834Z/report.txt"
    },
    {
      "id": "veloren-lan",
      "label": "Veloren LAN Candidate",
      "tier": "native-launcher-cached-server-pending",
      "catalogHub": "/mirrors/veloren-lan/",
      "ports": [
        "14004/tcp",
        "14004/udp"
      ],
