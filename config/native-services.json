      "smokeStatus": "server-tcp-smoke-passed",
      "adminState": "server-smoked",
      "packageNames": [
        "wesnoth-1.16-server"
      ],
      "lastReport": "qa/reports/service-smoke/wesnoth-lan-20260614T053253Z/report.txt"
    },
    {
      "id": "freecol-lan",
      "label": "FreeCol LAN Hub",
      "tier": "native-client-cached-and-vm-smoked",
      "catalogHub": "/mirrors/freecol-lan/",
      "ports": [],
