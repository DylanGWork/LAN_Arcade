# Player page and identity-checked control API.
location = /browser-stream {
    return 302 /browser-stream/;
}

# Internal authorization subrequest for noVNC HTML, assets, and WebSocket.
location = /browser-stream/_auth {
    internal;
    proxy_pass http://172.18.0.1:6081/authz;
    proxy_pass_request_body off;
    proxy_set_header Content-Length "";
    proxy_set_header Cookie $http_cookie;
    proxy_set_header Host $host;
}

location ^~ /browser-stream/vnc/ {
    auth_request /browser-stream/_auth;
    resolver 127.0.0.11 valid=10s;
    set $browser_stream_vnc http://lan-arcade-browser-stream:6080;
    rewrite ^/browser-stream/vnc/(.*)$ /$1 break;
    proxy_pass $browser_stream_vnc;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    add_header Cache-Control "no-store" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
}

location ^~ /browser-stream/ {
    proxy_pass http://172.18.0.1:6081/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_read_timeout 75s;
    proxy_send_timeout 75s;
    add_header Cache-Control "no-store" always;
}
