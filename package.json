{
  "name": "lan-arcade",
  "version": "0.1.0",
  "private": true,
  "description": "Offline LAN arcade mirror tooling and QA checks.",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @lan-arcade/shared && npm run build -w @lan-arcade/arcade-api && npm run build -w @lan-arcade/companion",
    "test": "npm run test -w @lan-arcade/shared && npm run test -w @lan-arcade/arcade-api && npm run test -w @lan-arcade/companion",
    "dev:api": "npm run dev -w @lan-arcade/arcade-api",
    "dev:companion": "npm run dev -w @lan-arcade/companion",
    "dev:tank": "node services/lan-tank-arena/server.mjs",
    "qa:static": "./audit_mirrors.sh ${MIRRORS_DIR:-/var/www/html/mirrors}",
    "qa:smoke": "node qa/arcade-smoke.mjs",
    "qa:smoke:catalog": "node qa/arcade-smoke.mjs --catalog",
    "qa:smoke:mobile": "node qa/arcade-smoke.mjs --mobile --report-dir qa/reports/latest-mobile",
    "qa:smoke:sample": "node qa/arcade-smoke.mjs --limit 5",
    "qa:companion": "node qa/companion-smoke.mjs",
    "qa:quarantine-blockers": "node qa/quarantine-blockers.mjs",
    "qa:summary": "node qa/qa-summary.mjs",
    "qa:summary:visible": "node qa/qa-summary.mjs --report qa/reports/latest-visible/smoke-report.json --output-dir qa/reports/latest-visible",
    "qa:patch-mirrors": "scripts/offline_patch_mirrors.sh",
    "qa:game": "bash scripts/qa_game_regression.sh",
    "qa:tank": "node qa/tank-arena-smoke.mjs",
    "qa:repair-assets": "node scripts/repair_missing_assets_from_report.mjs",
    "qa:repair-mirror-media": "python3 scripts/repair_mirror_external_media.py",
    "native:downloads:normalize": "python3 scripts/normalize_native_download_pages.py",
    "qa:launcher-adapters": "python3 scripts/audit_launcher_adapters.py",
    "rom:vault:build": "python3 scripts/build_private_rom_vault.py",
    "rom:vault:smoke": "node scripts/playtest_private_rom_vault.mjs",
    "dos:vault:build": "python3 scripts/build_private_dos_vault.py",
    "qa": "npm run qa:static && npm run qa:smoke",
    "native:public:cache": "python3 scripts/public_package_batch.py cache",
    "native:public:hubs": "python3 scripts/public_package_batch.py generate",
    "native:public:all": "python3 scripts/public_package_batch.py all",
    "native:public:smoke": "bash scripts/public_package_play_smoke.sh",
    "qa:library-platform": "python3 scripts/library_platform_audit.py",
    "native:services": "python3 scripts/native_service_admin.py",
    "qa:library-discovery": "node qa/library-discovery-smoke.mjs",
    "qa:git-identity": "bash scripts/check_git_identity.sh",
    "qa:secrets": "python3 scripts/check_tracked_secrets.py",
    "backup:user-data": "bash scripts/backup_arcade_user_data.sh",
    "qa:easy-launchers": "python3 scripts/plan_easy_launchers.py",
    "dos:vault:smoke": "node scripts/playtest_private_dos_vault.mjs",
    "qa:offline-links": "python3 scripts/audit_public_external_links.py --root ${MIRRORS_DIR:-/var/www/html/mirrors} && npm run qa:blocked-guides",
    "lemmings:build": "python3 scripts/build_lemmings_ts.py",
    "qa:lemmings": "node qa/lemmings-ts-smoke.mjs",
    "qa:blocked-guides": "python3 scripts/audit_blocked_public_guides.py --root ${MIRRORS_DIR:-/var/www/html/mirrors}",
    "qa:readiness": "node --test qa/readiness/core.test.mjs && node qa/readiness/live-invariants.mjs",
    "qa:readiness:compile": "node qa/readiness/build-readiness.mjs",
    "qa:readiness:browser": "node qa/readiness/browser-smoke.mjs",
    "qa:tank:live": "node qa/tank-arena-live-smoke.mjs",
    "qa:account-saves": "node qa/account-save-isolation-smoke.mjs",
    "qa:family-accounts": "node qa/family-account-browser-smoke.mjs",
    "qa:deployment-profiles": "node qa/deployment-profile.test.mjs",
    "qa:deployment-profile:browser": "node qa/deployment-profile-browser-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "20.19.1",
    "playwright": "1.59.1"
  },
  "overrides": {
    "tar": "7.5.13"
  }
}
